// ─── Prisma Schema — CyberteksIT LMS ───────────────────────────────────────
// Database: MongoDB Atlas
// ORM: Prisma 5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WAITLISTED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  SUSPENDED
  DROPPED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  DOCUMENT
  QUIZ
  ASSIGNMENT
  LIVE_SESSION
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

// ────────────────────────────────────────────────────────────────────────────
// USER
// ────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @map("_id") @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(STUDENT)
  phone         String?
  bio           String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  teacherCourses     Course[]         @relation("CourseTeacher")
  enrollments        Enrollment[]
  applications       Application[]
  invoices           Invoice[]
  certificates       Certificate[]
  notifications      Notification[]
  sentMessages       Message[]        @relation("MessageSender")
  receivedMessages   Message[]        @relation("MessageReceiver")
  lessonProgress     LessonProgress[]
  quizAttempts       QuizAttempt[]
  curriculumWeeks    CurriculumWeek[] @relation("TeacherCurriculum")
  teacherAssignments Assignment[]     @relation("TeacherAssignments")
  studentSubmissions Submission[]     @relation("StudentSubmissions")

  @@map("users")
}

// ────────────────────────────────────────────────────────────────────────────
// AUTH
// ────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @map("_id") @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @map("_id") @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @map("_id") @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ────────────────────────────────────────────────────────────────────────────
// APPLICATION
// ────────────────────────────────────────────────────────────────────────────

model Application {
  id              String            @id @map("_id") @default(cuid())
  userId          String?
  status          ApplicationStatus @default(PENDING)

  fullName        String
  email           String
  phone           String
  dateOfBirth     String
  gender          String
  cityCountry     String

  educationLevel    String
  educationOther    String?
  currentOccupation String?

  programs        String[]
  programOther    String?

  motivation      String
  careerGoals     String

  hoursPerWeek    String
  hasComputer     String
  deviceTypes     String[]
  hasInternet     String

  referralSource  String?
  socialHandle    String?

  tempPassword    String?

  reviewNotes     String?
  reviewedById    String?
  reviewedAt      DateTime?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("applications")
}

// ────────────────────────────────────────────────────────────────────────────
// COURSE
// ────────────────────────────────────────────────────────────────────────────

model Course {
  id          String       @id @map("_id") @default(cuid())
  title       String
  slug        String       @unique
  description String
  coverImage  String?
  price       Float        @default(0)
  currency    String       @default("UGX")
  status      CourseStatus @default(DRAFT)
  duration    String?
  level       String?
  category    String?
  tags        String[]

  teacherId   String
  teacher     User         @relation("CourseTeacher", fields: [teacherId], references: [id])

  sections        Section[]
  enrollments     Enrollment[]
  invoices        Invoice[]
  certificates    Certificate[]
  curriculumWeeks CurriculumWeek[]
  assignments     Assignment[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("courses")
}

// ────────────────────────────────────────────────────────────────────────────
// SECTION & LESSON
// ────────────────────────────────────────────────────────────────────────────

model Section {
  id       String   @id @map("_id") @default(cuid())
  title    String
  order    Int      @default(0)
  courseId String

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@map("sections")
}

model Lesson {
  id          String     @id @map("_id") @default(cuid())
  title       String
  description String?
  type        LessonType @default(VIDEO)
  content     String?
  duration    Int?
  order       Int        @default(0)
  isFree      Boolean    @default(false)
  sectionId   String

  section     Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]
  quiz        Quiz?

  @@map("lessons")
}

// ────────────────────────────────────────────────────────────────────────────
// QUIZ
// ────────────────────────────────────────────────────────────────────────────

model Quiz {
  id       String @id @map("_id") @default(cuid())
  title    String
  passMark Int    @default(70)
  lessonId String @unique

  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id      String @id @map("_id") @default(cuid())
  text    String
  options Json
  order   Int    @default(0)
  quizId  String

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id      String  @id @map("_id") @default(cuid())
  score   Float
  passed  Boolean
  answers Json
  userId  String
  quizId  String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("quiz_attempts")
}

// ────────────────────────────────────────────────────────────────────────────
// ENROLLMENT & PROGRESS
// ────────────────────────────────────────────────────────────────────────────

model Enrollment {
  id              String           @id @map("_id") @default(cuid())
  status          EnrollmentStatus @default(ACTIVE)
  progressPercent Float            @default(0)
  startedAt       DateTime         @default(now())
  completedAt     DateTime?

  userId   String
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id          String    @id @map("_id") @default(cuid())
  completed   Boolean   @default(false)
  completedAt DateTime?
  watchedSecs Int       @default(0)

  userId   String
  lessonId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

// ────────────────────────────────────────────────────────────────────────────
// CERTIFICATE
// ────────────────────────────────────────────────────────────────────────────

model Certificate {
  id            String   @id @map("_id") @default(cuid())
  certificateNo String   @unique @default(cuid())
  issuedAt      DateTime @default(now())

  userId   String
  courseId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("certificates")
}

// ────────────────────────────────────────────────────────────────────────────
// INVOICE
// ────────────────────────────────────────────────────────────────────────────

model Invoice {
  id        String        @id @map("_id") @default(cuid())
  invoiceNo String        @unique
  amount    Float
  currency  String        @default("UGX")
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?

  userId   String
  courseId String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invoices")
}

// ────────────────────────────────────────────────────────────────────────────
// MESSAGING
// ────────────────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @map("_id") @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String @id @map("_id") @default(cuid())
  userId         String
  conversationId String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
  @@map("conversation_participants")
}

model Message {
  id             String        @id @map("_id") @default(cuid())
  content        String
  status         MessageStatus @default(SENT)
  senderId       String
  receiverId     String
  conversationId String?

  sender       User          @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User          @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("messages")
}

// ────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @map("_id") @default(cuid())
  title     String
  body      String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ────────────────────────────────────────────────────────────────────────────
// CURRICULUM
// ────────────────────────────────────────────────────────────────────────────

model CurriculumWeek {
  id         String   @id @map("_id") @default(cuid())
  courseId   String
  teacherId  String
  weekNumber Int
  title      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course  Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher User              @relation("TeacherCurriculum", fields: [teacherId], references: [id], onDelete: Cascade)
  topics  CurriculumTopic[]

  @@map("curriculum_weeks")
}

model CurriculumTopic {
  id              String    @id @map("_id") @default(cuid())
  weekId          String
  title           String
  description     String?
  duration        String?
  type            String    @default("lecture")
  order           Int       @default(0)
  meetLink        String?
  meetScheduledAt DateTime?
  createdAt       DateTime  @default(now())

  week CurriculumWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@map("curriculum_topics")
}

// ────────────────────────────────────────────────────────────────────────────
// ASSIGNMENT & SUBMISSION
// ────────────────────────────────────────────────────────────────────────────

model Assignment {
  id             String   @id @map("_id") @default(cuid())
  title          String
  description    String?
  instructions   String?
  dueDate        DateTime
  maxScore       Int      @default(100)
  status         String   @default("DRAFT")
  attachmentUrl  String?
  attachmentName String?

  courseId  String
  teacherId String

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher     User         @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("assignments")
}

model Submission {
  id           String    @id @map("_id") @default(cuid())
  assignmentId String
  studentId    String
  content      String?
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  score        Float?
  feedback     String?
  status       String    @default("SUBMITTED")
  submittedAt  DateTime  @default(now())
  gradedAt     DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation("StudentSubmissions", fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@map("submissions")
}

// ────────────────────────────────────────────────────────────────────────────
// SUPPORT REQUEST
// ────────────────────────────────────────────────────────────────────────────

enum SupportRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportRequest {
  id     String               @id @map("_id") @default(cuid())
  status SupportRequestStatus @default(OPEN)

  fullName  String
  email     String
  phone     String?
  company   String?
  location  String?

  deviceType         String?
  os                 String?
  problemCategory    String?
  problemDescription String
  errorMessages      String?
  urgency            String  @default("Medium")

  remoteTool    String?
  remoteId      String?
  availableTime String?

  adminNotes String?
  repliedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_requests")
}

// ────────────────────────────────────────────────────────────────────────────
// OTP CODES
// ────────────────────────────────────────────────────────────────────────────

model OtpCode {
  id        String   @id @map("_id") @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

// ────────────────────────────────────────────────────────────────────────────
// NEWSLETTER
// ────────────────────────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id           String   @id @map("_id") @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())

  @@map("newsletter_subscribers")
}

// ────────────────────────────────────────────────────────────────────────────
// FREE BOOTCAMP
// ────────────────────────────────────────────────────────────────────────────

model FreeBootcamp {
  id            String   @id @map("_id") @default(cuid())
  title         String
  description   String
  bannerImage   String?
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  groupChatLink String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("free_bootcamps")
}
