# ── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres (or any Postgres-compatible connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cyberteks_lms?sslmode=require"

# ── Authentication ────────────────────────────────────────────────────────────
# Random secret for signing JWTs (generate with: openssl rand -hex 32)
JWT_SECRET="your-super-secret-jwt-key-change-me"

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Verified sender domain in Resend dashboard
RESEND_FROM_EMAIL="CyberteksIT LMS <noreply@cyberteks-it.com>"

# ── App URLs ──────────────────────────────────────────────────────────────────
# Frontend origin (used for CORS and password reset links)
CLIENT_URL="http://localhost:5173"

# ── Admin ─────────────────────────────────────────────────────────────────────
# Recipient for new application admin notifications
ADMIN_EMAIL="info@cyberteks-it.com"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
